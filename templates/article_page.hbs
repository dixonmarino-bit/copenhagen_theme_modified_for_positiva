<div class="container-divider"></div>
<div class="container positiva-content-page">
  <div class="sub-nav positiva-sub-nav">
    {{breadcrumbs}}
  </div>

  <article id="main-content" class="article positiva-article">
    <header class="article-header positiva-article-header">
      <h1 title="{{article.title}}" class="article-title positiva-article-title">
        {{article.title}}
      </h1>

      <div class="meta-group positiva-article-meta">
        {{#is article.created_at article.edited_at}}
          <span class="meta-data">{{date article.created_at}}</span>
        {{else}}
          <span class="meta-data">Actualizado {{date article.edited_at}}</span>
        {{/is}}
      </div>
    </header>

    <section class="article-info">
      <div class="article-content">
        <div class="article-body">{{article.body}}</div>

        {{#if attachments}}
          <div class="article-attachments">
            <ul class="attachments">
              {{#each attachments}}
                <li class="attachment-item">
                  <a href="{{url}}" target="_blank">{{name}}</a>
                  <div class="attachment-meta meta-group">
                    <span class="attachment-meta-item meta-data">{{size}}</span>
                    <a href="{{url}}" target="_blank" class="attachment-meta-item meta-data">Descargar</a>
                  </div>
                </li>
              {{/each}}
            </ul>
          </div>
        {{/if}}
      </div>
    </section>

    <div class="article-relatives positiva-related-cards">
      <h2>Más artículos</h2>
      <div class="positiva-articles-grid">
        {{#each section.articles}}
          {{#is id ../article.id}}
          {{else}}
            <a href="{{url}}" class="positiva-article-card">
              <div class="positiva-article-card-content">
                <p class="positiva-card-section">{{../section.name}}</p>
                <h3>{{title}}</h3>
                <p class="positiva-card-excerpt">Haz clic para leer este artículo.</p>
              </div>
              <div class="positiva-card-hover">
                <p>Abre el artículo para consultar todo el contenido en detalle.</p>
                <span>Leer artículo</span>
              </div>
            </a>
          {{/is}}
        {{/each}}
      </div>
      {{#if section.more_articles}}
        <a href="{{section.url}}" class="see-all-articles">Ver más artículos de esta sección</a>
      {{/if}}
    </div>
  </article>
</div>
