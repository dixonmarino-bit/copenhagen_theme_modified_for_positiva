<div class="container-divider"></div>
<div class="container positiva-content-page">
  <header class="page-header positiva-page-header" id="main-content">
    <h1>{{section.name}}</h1>
    {{#if section.description}}
      <p class="page-header-description">{{section.description}}</p>
    {{/if}}
  </header>

  {{#if section.articles}}
    <div class="positiva-articles-grid">
      {{#each section.articles}}
        <a href="{{url}}" class="positiva-article-card {{#if promoted}}is-promoted{{/if}}">
          <div class="positiva-article-card-content">
            <p class="positiva-card-section">{{../section.name}}</p>
            <h2>{{title}}</h2>
            <p class="positiva-card-excerpt">Haz clic para leer este artículo.</p>
          </div>
          <div class="positiva-card-hover">
            <p>Abre el artículo para consultar todo el contenido en detalle.</p>
            <span>Leer artículo</span>
          </div>
        </a>
      {{/each}}
    </div>
  {{/if}}

  {{pagination "section.articles"}}
</div>
